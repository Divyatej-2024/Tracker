{
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "strict": "off",
    "no-unused-vars": ["warn", { "args": "none", "ignoreRestSiblings": true }]
  }
}
